{
    "layer": "top",
    "position": "top",
    "mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 0,
    "modules-left": [
        "ext/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "custom/notification",
        "network",
        "battery",
        "pulseaudio",
        "custom/keyboard-layout"
    ],
    "tray": {
        "icon-size": 13,
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%A  ï‰²  %b %d  ïگ؛  %I:%M %p}",
        "interval": 1
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": [
            "َ°ƒ‍",
            "َ°ƒں",
            "َ°ƒ "
        ],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": [
            "َ°‚ƒ",
            "َ°پ؛",
            "َ°پ»",
            "َ°پ¼",
            "َ°پ½",
            "َ°پ¾",
            "َ°پ؟",
            "َ°‚€",
            "َ°‚پ",
            "َ°‚‚",
            "َ°پ¹"
        ]
    },
    "pulseaudio": {
        "format": "ï€¨  {volume}%",
        "on-click": "pavucontrol",
        // scroll
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },
    "custom/keyboard-layout": {
        "format": "âŒ¨ {}",
        "exec": "mmsg -g -k | awk '{print toupper($3)}'",
        "interval": 60,
        "signal": 1,
        "tooltip": false
    },
    "memory": {
        "interval": 10,
        "format": "َ°¾† {used}GB"
    },
    "cpu": {
        "interval": 10,
        "format": "َ°چ› {usage}%"
    },
    "network": {
        "format-wifi": "ï‡«  {essid}",
        "format-ethernet": "َ°ˆ€ ",
        "format-disconnected": "َ°–ھ ",
        "interval": 2
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{} {icon}",
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "sleep 0.1 && swaync-client -d -sw",
        "escape": true,
        "format-icons": {
            "notification": "َ±…«",
            "none": "ïƒ³",
            "dnd-notification": "ï‡¶",
            "dnd-none": "َ°‚›",
            "inhibited-notification": "ï‚¢",
            "inhibited-none": "ï‚¢",
            "dnd-inhibited-notification": "ï‡·",
            "dnd-inhibited-none": "ï‡·"
        }
    },
    "ext/workspaces": {
        "format": "{icon}",
        "ignore-hidden": true,
        "on-click": "activate",
        "on-click-right": "deactivate",
        "sort-by-id": true
    },
    "dwl/window": {
        "format": "{title}"
    }
}
